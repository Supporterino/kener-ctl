{
  "name": "kener-ctl",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "kener-ctl": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --outdir dist --target bun --external node-fetch-native --external giget",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "release": "bun build --compile src/cli/index.ts --outfile dist/kener-ctl"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "citty": "^0.1.6",
    "cli-table3": "^0.6.5",
    "consola": "^3.4.2",
    "fast-deep-equal": "^3.1.3",
    "js-yaml": "^4.2.0",
    "ky": "^1.14.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/js-yaml": "^4.0.9",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
